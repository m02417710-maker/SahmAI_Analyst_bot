# ملف: .env.example
# المسار: /trading_platform/.env.example

# Gemini API Key (للذكاء الاصطناعي)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot Token
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Database (اختياري - القيم الافتراضية موجودة)
DB_USER=trader
DB_PASSWORD=secure_password_2024
DB_NAME=trading_db
DB_HOST=timescaledb
DB_PORT=5432

# Redis
REDIS_PASSWORD=redis_secure_pass
REDIS_HOST=redis
REDIS_PORT=6379

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Market Settings
MARKET_UPDATE_INTERVAL=60  # seconds
CACHE_TTL=5  # seconds

# Logging
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # seconds
