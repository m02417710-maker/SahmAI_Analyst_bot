name: Stock Daily Check

on:
  schedule:
    - cron: '0 8 * * 1-5' # يعمل الساعة 8 صباحاً بتوقيت UTC من الاثنين للجمعة
  workflow_dispatch: # يسمح لك بتشغيله يدوياً أيضاً

jobs:
  check_stocks:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.9'
      - name: Install dependencies
        run: pip install yfinance pandas_ta google-generativeai
      - name: Run analysis script
        env:
          GEMINI_API_KEY: ${{ secrets.GEMINI_API_KEY }}
        run: python your_analysis_script.py # ملف صغير لعمل التحليل وإرسال إشعار
