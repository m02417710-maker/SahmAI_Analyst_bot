# ملف: .env.example
# المسار: /trading_platform/.env.example
# الوظيفة: متغيرات البيئة للمشروع

# ====================== API Keys ======================
# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (ChatGPT)
OPENAI_API_KEY=your_openai_api_key_here

# Stripe (للمدفوعات)
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Telegram Bot
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ====================== Database ======================
DB_USER=trader
DB_PASSWORD=secure_password_2024
DB_NAME=trading_db_prod
DB_HOST=timescaledb
DB_PORT=5432

# ====================== Redis ======================
REDIS_PASSWORD=redis_secure_pass
REDIS_HOST=redis
REDIS_PORT=6379

# ====================== Server ======================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
ENVIRONMENT=production

# ====================== Market Settings ======================
MARKET_UPDATE_INTERVAL=60
CACHE_TTL=5
REALTIME_UPDATE_INTERVAL=5

# ====================== Security ======================
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

CORS_ORIGINS=["https://trading-platform.com"]
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ====================== Email ======================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
ADMIN_EMAIL=admin@trading-platform.com

# ====================== Tax Settings ======================
TAX_RATE=0.225
TAX_AUTHORITY_ID=123456
TAX_COUNTRY=EG

# ====================== Monitoring ======================
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
PROMETHEUS_ENABLED=true
GRAFANA_PASSWORD=admin_secure_password

# ====================== Competition ======================
DAILY_COMPETITION_ENABLED=true
WEEKLY_COMPETITION_ENABLED=true
MONTHLY_COMPETITION_ENABLED=true

# ====================== Social ======================
SOCIAL_FEED_CACHE_SECONDS=30
MAX_POSTS_PER_USER_DAY=10
MAX_COMMENTS_PER_POST=100

# ====================== Voice Assistant ======================
VOICE_ENABLED=true
VOICE_LANGUAGE=ar
VOICE_RECOGNITION_TIMEOUT=5

# ====================== Features ======================
FEATURE_AUTO_TRADING=true
FEATURE_COPY_TRADING=true
FEATURE_SOCIAL_TRADING=true
FEATURE_VOICE_ASSISTANT=true
FEATURE_AI_CHAT=true
